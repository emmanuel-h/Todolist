<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!--
        TOP DIVIDER — same colour as the completed-section divider, giving
        the ghost row a minimal affordance (Option D).
    -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="?attr/colorOutlineVariant" />

    <!--
        GHOST ROW — visible when the field is not focused.
        Tapping it requests focus on the hidden EditText which then
        reveals the EXPANDED ROW.
    -->
    <LinearLayout
        android:id="@+id/ghostRow"
        android:layout_width="match_parent"
        android:layout_height="@dimen/inline_add_ghost_height"
        android:background="?attr/selectableItemBackground"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:visibility="visible">

        <ImageView
            android:layout_width="@dimen/inline_add_leading_spacer"
            android:layout_height="24dp"
            android:importantForAccessibility="no"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:scaleType="fitCenter"
            app:srcCompat="@drawable/ic_add"
            app:tint="?attr/colorPrimary" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/textGhostHint"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:importantForAccessibility="no"
            android:text="@string/add_item_ghost_hint"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textColor="?attr/colorPrimary" />

    </LinearLayout>

    <!--
        EXPANDED ROW — visible only when the EditText is focused.
        No TextInputLayout wrapper so the EditText left edge aligns
        exactly with the ghost-row text, preventing a visual width jump.
    -->
    <LinearLayout
        android:id="@+id/expandedRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:minHeight="56dp"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="4dp"
        android:visibility="gone">

        <Space
            android:layout_width="@dimen/inline_add_leading_spacer"
            android:layout_height="1dp" />

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/editInlineAdd"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@null"
            android:hint="@string/add_item_hint"
            android:imeOptions="actionDone"
            android:inputType="textCapSentences"
            android:maxLines="1"
            android:paddingStart="0dp"
            android:paddingEnd="0dp"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textColor="?attr/colorOnSurface" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnInlineSubmit"
            style="@style/Widget.Material3.Button.IconButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:contentDescription="@string/submit_inline_add"
            app:icon="@drawable/ic_arrow_forward"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconTint="?attr/colorPrimary" />

    </LinearLayout>

</LinearLayout>
